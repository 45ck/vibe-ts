#!/usr/bin/env sh
set -e
# Beads + Husky chained pre-commit hook
#
# 1. Runs bd hook pre-commit (skips gracefully if bd not installed)
# 2. Runs npx lint-staged (original Husky behaviour)

# ── bd integration ──
if command -v bd >/dev/null 2>&1; then
    bd hook pre-commit "$@"
fi

# ── Husky: lint-staged ──
npx lint-staged

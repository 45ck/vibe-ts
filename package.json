{
  "name": "vibe-ts",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Quality-first TypeScript template for AI-assisted development. DDD architecture with enforced boundaries.",
  "license": "MIT",
  "packageManager": "npm@10.8.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "spell": "cspell --no-progress --config cspell.json \"{packages,apps}/*/src/**/*\" \"*.md\" \"{packages,apps}/*/*.md\"",
    "knip": "knip --production",
    "depcruise": "npm run depcruise --workspaces --if-present",
    "depgraph": "npm run depgraph --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:fast": "npm run typecheck && npm run lint && npm run format:check && npm run depcruise",
    "install:fast": "npm ci --prefer-offline --no-audit --no-fund",
    "mutation": "npm run mutation --workspaces --if-present",
    "audit:high": "node scripts/ci/audit-high.mjs",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run spell && npm run depcruise && npm run knip && npm run test:coverage && npm run audit:high",
    "ci:nightly": "npm run ci && npm run mutation",
    "quality": "npm run quality:fast && npm run quality:slow && npm run quality:ci",
    "quality:fast": "noslop check --tier=fast",
    "quality:slow": "noslop check --tier=slow",
    "quality:ci": "noslop check --tier=ci",
    "docs:agent-check": "node scripts/docs/run-agent-docs.mjs check .",
    "docs:agent-generate": "node scripts/docs/run-agent-docs.mjs generate .",
    "docs:sync": "node scripts/docs/sync-docs.mjs --write",
    "docs:check": "npm run docs:agent-check && node scripts/docs/sync-docs.mjs --check",
    "docs:generate": "npm run docs:agent-generate && npm run docs:sync",
    "bd": "node scripts/beads/bd.mjs",
    "bd:verify": "node scripts/beads/verify-bd-integration.mjs",
    "bd:sync": "bd sync",
    "bd:ready": "bd ready",
    "bd:daemon:start": "bd daemon start --auto-commit",
    "bd:daemon:stop": "bd daemon stop",
    "bd:doctor": "bd doctor",
    "bd:prime": "bd prime",
    "bd:dep": "bd dep",
    "agent:context": "node scripts/agent/context.mjs",
    "agent:context:json": "node scripts/agent/context.mjs --json",
    "agent:seed-issues": "node scripts/agent/seed-issues.mjs",
    "agent:handoff": "node scripts/agent/handoff.mjs",
    "agent:spawn": "node scripts/agent/spawn-team.mjs",
    "agent:verify-hooks": "node scripts/agent/verify-guardrails.mjs",
    "agent:verify": "node scripts/agent/verify-guardrails.mjs",
    "template:create": "node scripts/bootstrap/create-template.mjs",
    "admin:branch-protection": "node scripts/admin/ensure-branch-protection.mjs",
    "admin:branch-protection:apply": "node scripts/admin/ensure-branch-protection.mjs --apply",
    "prepare": "node scripts/bootstrap/prepare-hooks.mjs"
  },
  "bin": {
    "create-vibets": "scripts/agent/spawn-team.mjs",
    "vibe-ts": "scripts/bootstrap/create-template-cli.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "node node_modules/eslint/bin/eslint.js --fix",
      "node node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.{md,mdx,json,yml,yaml}": [
      "node node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "devDependencies": {
    "@45ck/agent-docs": "github:45ck/agent-docs",
    "@45ck/noslop": "^1.0.0",
    "@eslint/js": "^9.0.0",
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/typescript-checker": "^9.4.0",
    "@stryker-mutator/vitest-runner": "^9.4.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "cspell": "^9.6.0",
    "dependency-cruiser": "^17.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "knip": "^5.0.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}

{
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git worktree *)",
      "Bash(git branch *)",
      "Bash(git merge *)",
      "Bash(git config *)",
      "Bash(bd ready)",
      "Bash(bd ready --json)",
      "Bash(bd issue next --json)",
      "Bash(bd issue view *)",
      "Bash(bd issue start *)",
      "Bash(bd issue finish *)",
      "Bash(bd issue unclaim *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Bash(rm -rf *)",
      "Bash(*--no-verify*)",
      "Bash(*--force*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Edit(.beads/hooks/**)",
      "Edit(.github/workflows/**)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/hooks/**)",
      "Edit(eslint.config.mjs)",
      "Edit(vitest.config.ts)",
      "Edit(.dependency-cruiser.cjs)",
      "Edit(tsconfig.json)",
      "Edit(tsconfig.build.json)",
      "Write(.beads/hooks/**)",
      "Write(.github/workflows/**)",
      "Write(.claude/settings.json)",
      "Write(.claude/hooks/**)",
      "Write(eslint.config.mjs)",
      "Write(vitest.config.ts)",
      "Write(.dependency-cruiser.cjs)",
      "Write(tsconfig.json)",
      "Write(tsconfig.build.json)"
    ]
  }
}

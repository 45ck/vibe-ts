{
  "name": "@repo/example",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "dependencies": {
    "@repo/shared": "*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "depcruise": "dependency-cruiser --config .dependency-cruiser.cjs --validate --output-type err src",
    "depgraph": "dependency-cruiser --config .dependency-cruiser.cjs --output-type mermaid src --output-to ../../reports/example-dependency-graph.mmd",
    "mutation": "stryker run"
  }
}
